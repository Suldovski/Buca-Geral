@page "/obras"
@layout MainLayout
@using BucaGeral.Web.Services
@using BucaGeral.Models
@inject ApiService ApiService
@inject ILogger<Obras> Logger

<div class="obras-container">
    <div class="page-header">
        <h1>🏗️ Obras</h1>
        <button class="btn btn-success" @onclick="NovaObra">
            ➕ Nova Obra
        </button>
    </div>

    @if (Carregando)
    {
        <div style="text-align: center; padding: var(--spacing-xl);">
            <p>⏳ Carregando obras...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(Erro))
    {
        <div class="alert alert-danger">
            ❌ @Erro
        </div>
    }
    else
    {
        <!-- Grid de Cards -->
        @if (Obras.Count == 0)
        {
            <div class="empty-state">
                <p>Nenhuma obra cadastrada.</p>
                <button class="btn btn-primary" @onclick="NovaObra" style="margin-top: var(--spacing-md);">
                    ➕ Cadastrar Primeira Obra
                </button>
            </div>
        }
        else
        {
            <div class="obras-grid">
                @foreach (var obra in Obras)
                {
                    var qtdFunc = Funcionarios.Count(f => f.ObraId == obra.Id);
                    <div class="obra-card">
                        <div class="obra-header">
                            <div>
                                <h3>@obra.Nome</h3>
                                <p style="color: var(--light); font-size: 12px; margin: 0;">@obra.Codigo</p>
                            </div>
                            @{
                                var statusEmoji = obra.Status == "em-andamento" ? "🟢" : "🔴";
                            }
                            <span style="font-size: 24px;">@statusEmoji</span>
                        </div>

                        <div class="obra-body">
                            <p><strong>📍 Localização:</strong> @obra.Localizacao</p>
                            <p><strong>📅 Início:</strong> @obra.DataInicio?.ToString("dd/MM/yyyy")</p>
                            <p><strong>👥 Funcionários:</strong> @qtdFunc</p>
                        </div>

                        <div class="obra-actions">
                            <button class="btn btn-primary btn-sm" @onclick="() => EditarObra(obra)">
                                ✏️ Editar
                            </button>
                            <button class="btn btn-danger btn-sm" @onclick="() => DeletarObra(obra.Id)">
                                🗑️ Deletar
                            </button>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Tabela Alternativa (Desktop) -->
        @if (Obras.Count > 0)
        {
            <div style="margin-top: var(--spacing-xl); display: none;">
                <h3 style="margin-bottom: var(--spacing-md);">📋 Tabela Resumida</h3>
                <div class="table-responsive">
                    <table class="tabela-funcionarios">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Nome</th>
                                <th>Localização</th>
                                <th>Funcionários</th>
                                <th>Status</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var obra in Obras)
                            {
                                var qtdFunc = Funcionarios.Count(f => f.ObraId == obra.Id);
                                <tr>
                                    <td><strong>@obra.Codigo</strong></td>
                                    <td>@obra.Nome</td>
                                    <td>@obra.Localizacao</td>
                                    <td><span class="badge badge-info">@qtdFunc</span></td>
                                    <td>
                                        @{
                                            var statusClass = obra.Status == "em-andamento" ? "badge-success" : "badge-secondary";
                                            var statusText = obra.Status == "em-andamento" ? "Em Andamento" : "Concluída";
                                        }
                                        <span class="badge @statusClass">@statusText</span>
                                    </td>
                                    <td>
                                        <button class="btn-icon" @onclick="() => EditarObra(obra)">✏️</button>
                                        <button class="btn-icon" @onclick="() => DeletarObra(obra.Id)">🗑️</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Obra> Obras = new();
    private List<Funcionario> Funcionarios = new();
    private bool Carregando = true;
    private string Erro = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Carregando = true;
            Erro = "";

            Obras = await ApiService.GetObrasAsync();
            Funcionarios = await ApiService.GetFuncionariosAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError($"Erro ao carregar obras: {ex.Message}");
            Erro = $"Erro ao carregar dados: {ex.Message}";
        }
        finally
        {
            Carregando = false;
        }
    }

    private void NovaObra()
    {
        // TODO: Abrir modal para nova obra
    }

    private void EditarObra(Obra obra)
    {
        // TODO: Abrir modal para editar obra
    }

    private async Task DeletarObra(string id)
    {
        try
        {
            if (await ConfirmarAcao("Tem certeza que deseja deletar esta obra?"))
            {
                await ApiService.DeleteObraAsync(id);
                Obras.RemoveAll(o => o.Id == id);
                Logger.LogInformation("Obra deletada com sucesso");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError($"Erro ao deletar: {ex.Message}");
            Erro = "Erro ao deletar obra";
        }
    }

    private Task<bool> ConfirmarAcao(string mensagem)
    {
        return Task.FromResult(confirm(mensagem));
    }
}
