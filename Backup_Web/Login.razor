@page "/login"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Authorization
@using BucaGeral.Web.Services
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider

<PageTitle>Buca Geral - Acesso</PageTitle>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <img src="/logo.png" alt="Logo Buca Geral" class="logo" />
            <h2>Buca Geral</h2>
            <p>Gestão de RH Multi-Obras</p>
        </div>

        <div class="login-body">
            <EditForm Model="@loginModel" OnValidSubmit="@HandleLogin">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />

                <div class="form-group">
                    <label for="email">E-mail</label>
                    <InputText id="email" class="form-control" @bind-Value="loginModel.Email" />
                    <ValidationMessage For="@(() => loginModel.Email)" />
                </div>

                <div class="form-group">
                    <label for="senha">Senha</label>
                    <InputText id="senha" type="password" class="form-control" @bind-Value="loginModel.Senha" />
                    <ValidationMessage For="@(() => loginModel.Senha)" />
                </div>

                <button type="submit" class="btn-login" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner"></span>
                    }
                    else
                    {
                        <text>Entrar</text>
                    }
                </button>
            </EditForm>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert-danger mt-3">@errorMessage</div>
            }
        </div>

        <div class="login-footer">
            <a href="/registrar">Criar nova conta</a>
        </div>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private bool isLoading = false;
    private string errorMessage = string.Empty;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var http = new HttpClient();
            var response = await http.PostAsJsonAsync("http://localhost:5000/api/Auth/login", loginModel);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                
                if (result != null && AuthProvider is CustomAuthStateProvider customAuth)
                {
                    customAuth.MarkUserAsAuthenticated(result.email ?? "", result.nome ?? "", result.uid ?? "");
                }
                
                Navigation.NavigateTo("/", true);
            }
            else
            {
                errorMessage = "E-mail ou senha inválidos.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro de conexão: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class LoginModel
    {
        public string Email { get; set; } = "";
        public string Senha { get; set; } = "";
    }

    public class LoginResponse
    {
        public string? mensagem { get; set; }
        public string? uid { get; set; }
        public string? email { get; set; }
        public string? nome { get; set; }
    }
}
