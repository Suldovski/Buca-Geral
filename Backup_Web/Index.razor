@page "/"

<h1>Bem-vindo ao Buca-Geral</h1>
<p>Sistema de gestão de RH multi-obras</p>

<div class="alert alert-info mt-4">
    <strong>Status da API:</strong> 
    <span class="badge" style="background-color: @(statusApi == "Online" ? "green" : "red")">
        @statusApi
    </span>
</div>

<button class="btn btn-primary" @onclick="TestarApi">Testar Conexão</button>

@if (!string.IsNullOrEmpty(mensagem))
{
    <div class="alert alert-secondary mt-3">
        @mensagem
    </div>
}

@code {
    private string statusApi = "Verificando...";
    private string mensagem = "";

    protected override async Task OnInitializedAsync()
    {
        await TestarApi();
    }

    private async Task TestarApi()
    {
        try
        {
            var http = new HttpClient();
            var resultado = await http.GetStringAsync("http://localhost:5000/api/Teste");
            statusApi = "Online";
            mensagem = $"Resposta da API: {resultado}";
        }
        catch (Exception ex)
        {
            statusApi = "Offline";
            mensagem = $"Erro: {ex.Message}";
        }
    }
}
