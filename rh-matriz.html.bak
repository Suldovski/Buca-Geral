<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>RH Matriz - Buca-Geral</title>
    <link rel="stylesheet" href="style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
<div class="header"><div class="logo">🏗️ Buca-Geral</div><div class="menu"><a href="home.html">Home</a><a href="obras.html">Obras</a><a href="rh-matriz.html">RH Matriz</a><a href="usuarios.html">Usuários</a><a href="index.html">Sair</a></div></div>
<div class="container"><div class="card"><h2>👥 RH Matriz - Todos os Funcionários</h2><div class="filtros"><div class="form-group"><input type="text" id="searchInput" placeholder="🔍 Buscar..."></div><div class="form-group"><select id="filtroObra"><option value="">Todas as obras</option></select></div></div><div style="margin-bottom: 30px;"><canvas id="graficoMatriz" style="max-height: 300px;"></canvas></div><table id="tabelaFunc"><thead><tr><th>Nome</th><th>Cargo</th><th>Obra</th><th>Admissão</th><th>Ações</th></tr></thead><tbody></tbody></table></div></div>
<script>
const API = 'http://localhost:5000/api';
let funcionarios = [], obras = [], graficoMatriz;
async function carregarDados() {
    [funcionarios, obras] = await Promise.all([fetch(`${API}/funcionarios`).then(r=>r.json()), fetch(`${API}/obras`).then(r=>r.json())]);
    const select = document.getElementById('filtroObra'); select.innerHTML = '<option value="">Todas as obras</option>';
    obras.forEach(o => { select.innerHTML += `<option value="${o.id}">${o.nome}</option>`; });
    atualizarGrafico();
    renderizar();
}
function atualizarGrafico() {
    const labels = obras.map(o => o.nome);
    const data = obras.map(o => funcionarios.filter(f => f.obraId === o.id).length);
    if(graficoMatriz) graficoMatriz.destroy();
    graficoMatriz = new Chart(document.getElementById('graficoMatriz'), { type: 'bar', data: { labels, datasets: [{ label: 'Funcionários por Obra', data, backgroundColor: '#2a5298' }] } });
}
function renderizar() { const busca = document.getElementById('searchInput').value.toLowerCase(); const obraId = document.getElementById('filtroObra').value; const filtrados = funcionarios.filter(f => (!obraId || f.obraId === obraId) && (f.nome.toLowerCase().includes(busca) || f.cargo.toLowerCase().includes(busca) || (obras.find(o=>o.id===f.obraId)?.nome||'').toLowerCase().includes(busca))); const tbody = document.querySelector('#tabelaFunc tbody'); tbody.innerHTML = ''; filtrados.forEach(f => { const obraNome = obras.find(o => o.id === f.obraId)?.nome || 'N/A'; tbody.innerHTML += `<tr><td>${f.nome}</td><td>${f.cargo}</td><td>${obraNome}</td><td>${new Date(f.dataAdmissao).toLocaleDateString()}</td><td><button class="btn btn-sm btn-warning" onclick="editarFunc('${f.id}')">Editar</button> <button class="btn btn-sm btn-danger" onclick="excluirFunc('${f.id}')">Excluir</button></td>`; }); }
async function editarFunc(id){ const f = funcionarios.find(x=>x.id===id); if(f) window.location.href = `obra-detalhe.html?id=${f.obraId}`; }
async function excluirFunc(id){ const result = await Swal.fire({ title:'Excluir funcionário?', icon:'warning', showCancelButton:true }); if(result.isConfirmed){ await fetch(`${API}/funcionarios/${id}`, { method:'DELETE' }); carregarDados(); Swal.fire('Excluído!','','success'); } }
document.getElementById('searchInput').addEventListener('input', renderizar);
document.getElementById('filtroObra').addEventListener('change', renderizar);
carregarDados();
</script>
</body>
</html>
