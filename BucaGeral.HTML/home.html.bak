<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Home - Buca-Geral</title>
    <link rel="stylesheet" href="style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
<div class="header">
    <div class="logo">🏗️ Buca-Geral</div>
    <div class="menu">
        <a href="home.html">Home</a>
        <a href="obras.html">Obras</a>
        <a href="rh-matriz.html">RH Matriz</a>
        <a href="usuarios.html">Usuários</a>
        <a href="index.html" id="sairBtn">Sair</a>
    </div>
</div>
<div class="container">
    <div class="stats">
        <div class="stat-card"><div class="stat-number" id="totalObras">-</div><div class="stat-label">Total de Obras</div></div>
        <div class="stat-card"><div class="stat-number" id="totalFuncionarios">-</div><div class="stat-label">Total de Funcionários</div></div>
        <div class="stat-card" style="background:#fff3cd;"><div class="stat-number" id="exp30dias">-</div><div class="stat-label">⚠️ Exames vencem em 30 dias</div></div>
        <div class="stat-card" style="background:#f8d7da;"><div class="stat-number" id="expVencidos">-</div><div class="stat-label">❌ Exames vencidos</div></div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
        <div class="card"><h3>📊 Funcionários por Obra</h3><canvas id="graficoObras" style="max-height: 300px;"></canvas></div>
        <div class="card"><h3>🥧 Distribuição por Cargo</h3><canvas id="graficoCargos" style="max-height: 300px;"></canvas></div>
    </div>

    <div class="card"><h3>📈 Evolução de Admissões (últimos 6 meses)</h3><canvas id="graficoEvolucao" style="max-height: 300px;"></canvas></div>

    <div class="card"><h3>📋 Últimas Obras Cadastradas</h3><table id="ultimasObras"><thead><tr><th>Nome</th><th>Localização</th><th>Funcionários</th><th>Ação</th></tr></thead><tbody><tr><td colspan="4">Carregando...</td></tr></tbody></table></div>
</div>
<script>
const API = 'http://localhost:5000/api';
let graficoObras, graficoCargos, graficoEvolucao;

function calcularDiferencaDias(data) {
    const hoje = new Date();
    const dataExp = new Date(data);
    const diff = Math.ceil((dataExp - hoje) / (1000 * 60 * 60 * 24));
    return diff;
}

async function carregarStats() {
    const [obras, funcs] = await Promise.all([fetch(`${API}/obras`).then(r=>r.json()), fetch(`${API}/funcionarios`).then(r=>r.json())]);
    document.getElementById('totalObras').innerText = obras.length;
    document.getElementById('totalFuncionarios').innerText = funcs.length;

    let exp30 = 0, expVencidos = 0;
    funcs.forEach(f => {
        if(f.exp30) { const dias = calcularDiferencaDias(f.exp30); if(dias <= 30 && dias >= 0) exp30++; }
        if(f.exp60) { const dias = calcularDiferencaDias(f.exp60); if(dias < 0) expVencidos++; }
    });
    document.getElementById('exp30dias').innerText = exp30;
    document.getElementById('expVencidos').innerText = expVencidos;

    // Gráfico Obras
    const labelsObras = obras.map(o => o.nome);
    const dataObras = obras.map(o => funcs.filter(f => f.obraId === o.id).length);
    if(graficoObras) graficoObras.destroy();
    graficoObras = new Chart(document.getElementById('graficoObras'), { type: 'bar', data: { labels: labelsObras, datasets: [{ label: 'Funcionários', data: dataObras, backgroundColor: '#2a5298' }] } });

    // Gráfico Cargos
    const cargos = {};
    funcs.forEach(f => { cargos[f.cargo] = (cargos[f.cargo] || 0) + 1; });
    if(graficoCargos) graficoCargos.destroy();
    graficoCargos = new Chart(document.getElementById('graficoCargos'), { type: 'pie', data: { labels: Object.keys(cargos), datasets: [{ data: Object.values(cargos), backgroundColor: ['#2a5298','#28a745','#ffc107','#dc3545','#17a2b8'] }] } });

    // Evolução últimos 6 meses
    const meses = [];
    for(let i=5;i>=0;i--) { const d = new Date(); d.setMonth(d.getMonth() - i); meses.push(d.toLocaleDateString('pt-BR',{month:'short',year:'numeric'})); }
    const qtdMeses = meses.map(m => funcs.filter(f => new Date(f.dataAdmissao).toLocaleDateString('pt-BR',{month:'short',year:'numeric'}) === m).length);
    if(graficoEvolucao) graficoEvolucao.destroy();
    graficoEvolucao = new Chart(document.getElementById('graficoEvolucao'), { type: 'line', data: { labels: meses, datasets: [{ label: 'Novos funcionários', data: qtdMeses, borderColor: '#2a5298', fill: true }] } });

    let html = '';
    obras.slice(-5).reverse().forEach(o => { const qtd = funcs.filter(f => f.obraId === o.id).length; html += `<tr><td style="cursor:pointer" onclick="verObra('${o.id}')"><strong>${o.nome}</strong></td><td onclick="verObra('${o.id}')">${o.localizacao}</td><td onclick="verObra('${o.id}')">${qtd}</td><td><a href="obra-detalhe.html?id=${o.id}" class="btn btn-sm">Ver Obra</a></td>`; });
    document.querySelector('#ultimasObras tbody').innerHTML = html || '<tr><td colspan="4">Nenhuma obra cadastrada</td></tr>';
}
function verObra(id) { window.location.href = `obra-detalhe.html?id=${id}`; }
document.getElementById('sairBtn')?.addEventListener('click', (e) => { e.preventDefault(); localStorage.clear(); window.location.href='index.html'; });
carregarStats();
</script>
</body>
</html>
