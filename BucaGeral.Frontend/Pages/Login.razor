@page "/login"
@using System.Net.Http.Json
@inject NavigationManager Navigation

<div style="max-width: 400px; margin: 100px auto; padding: 20px; border: 1px solid #ccc; border-radius: 10px;">
    <h2 style="text-align: center;">Buca-Geral</h2>
    <h4 style="text-align: center;">Sistema de RH</h4>
    <hr />

    <EditForm OnValidSubmit="@HandleLogin">
        <div style="margin-bottom: 15px;">
            <label>E-mail:</label>
            <InputText class="form-control" @bind-Value="loginRequest.Email" style="width: 100%; padding: 8px;" />
        </div>

        <div style="margin-bottom: 15px;">
            <label>Senha:</label>
            <InputText type="password" class="form-control" @bind-Value="loginRequest.Senha" style="width: 100%; padding: 8px;" />
        </div>

        <button type="submit" style="width: 100%; padding: 10px; background: #007bff; color: white; border: none; border-radius: 5px;">
            Entrar
        </button>
    </EditForm>

    @if (!string.IsNullOrEmpty(erro))
    {
        <div style="margin-top: 15px; padding: 10px; background: #fee; color: red; border-radius: 5px;">
            @erro
        </div>
    }
</div>

@code {
    private LoginRequest loginRequest = new();
    private string erro = "";

    private async Task HandleLogin()
    {
        erro = "";
        
        try
        {
            var http = new HttpClient();
            var response = await http.PostAsJsonAsync("http://localhost:5000/api/Auth/login", loginRequest);
            
            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/", true);
            }
            else
            {
                erro = "E-mail ou senha inválidos.";
            }
        }
        catch (Exception ex)
        {
            erro = $"Erro: {ex.Message}";
        }
    }

    public class LoginRequest
    {
        public string Email { get; set; } = "";
        public string Senha { get; set; } = "";
    }
}
